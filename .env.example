# Hubora — exemplo local. Nunca comite valores reais.
# No Netlify, configure as mesmas chaves em Project configuration > Environment variables.

# -----------------------------------------------------------------------------
# Acesso pessoal e Supabase — obrigatório para login e sincronização
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_EXEMPLO

# Aplicação pública multiusuário. Contas autenticadas sincronizam somente seus
# próprios dados, protegidos por RLS no Supabase. Visitantes usam dados locais.
VITE_REQUIRE_AUTH=false
VITE_ALLOW_PUBLIC_SIGNUP=true
VITE_ALLOW_GUEST_MODE=true

# Recursos públicos do frontend
VITE_ENABLE_EMAIL_LOGIN=true
VITE_ENABLE_REMOTE_RADAR=true
# Ativa o service worker também no servidor de desenvolvimento local.
VITE_ENABLE_PWA=false

# -----------------------------------------------------------------------------
# Supabase no backend — obrigatório para notificações e verificações administrativas
# -----------------------------------------------------------------------------
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_EXEMPLO
SUPABASE_SECRET_KEY=sb_secret_EXEMPLO

# -----------------------------------------------------------------------------
# Catálogo de filmes, séries e doramas — configure UMA das opções TMDB
# -----------------------------------------------------------------------------
TMDB_API_KEY=
TMDB_API_READ_TOKEN=

# -----------------------------------------------------------------------------
# Jogos
# -----------------------------------------------------------------------------
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
RAWG_API_KEY=

# -----------------------------------------------------------------------------
# Livros — recomendado para cota e identificação do aplicativo
# -----------------------------------------------------------------------------
GOOGLE_BOOKS_API_KEY=

# -----------------------------------------------------------------------------
# Operação
# -----------------------------------------------------------------------------
# Limite por minuto do servidor Express local. Netlify Functions também usam
# seus próprios limites declarados em cada função.
HUBORA_API_RATE_LIMIT=120

# -----------------------------------------------------------------------------
# Somente testes E2E locais/CI. Não configure na produção sem necessidade.
# -----------------------------------------------------------------------------
HUBORA_E2E_EMAIL=hubora-e2e@example.invalid
HUBORA_E2E_PASSWORD=
HUBORA_NETLIFY_URL=https://hubora.netlify.app/
HUBORA_E2E_STORAGE_STATE=.playwright/hubora-e2e.json
