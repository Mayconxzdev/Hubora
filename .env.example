# Exemplo de configuração de variáveis de ambiente do Hubora

# API TMDB (Filmes, Séries, Doramas)
VITE_TMDB_API_KEY=sua_chave_tmdb_aqui

# Supabase (Autenticação e Banco na Nuvem)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_chave_publica_supabase

# Netlify Serverless Proxy (Chaves Privadas)
TMDB_API_KEY=sua_chave_tmdb_aqui
IGDB_CLIENT_ID=seu_client_id_igdb
IGDB_CLIENT_SECRET=seu_client_secret_igdb
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SECRET_KEY=sua_chave_secreta_supabase
