# Cliente web. Valores VITE_ são incluídos no bundle e não podem ser segredos.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_REQUIRE_AUTH=true
VITE_ALLOW_PUBLIC_SIGNUP=false
VITE_ENABLE_EMAIL_LOGIN=true
VITE_ALLOWED_EMAILS=
VITE_ENFORCE_SERVER_ALLOWLIST=true
VITE_ENABLE_REMOTE_RADAR=true

# Somente Netlify Functions. Configure no painel do Netlify; nunca use prefixo VITE_.
SUPABASE_URL=
# Server only. Prefer the new Supabase secret key format. Never use VITE_ here.
SUPABASE_SECRET_KEY=
# Legacy alternative (do not configure both):
SUPABASE_SERVICE_ROLE_KEY=
TMDB_API_KEY=
TMDB_API_READ_TOKEN=
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
GOOGLE_BOOKS_API_KEY=
RAWG_API_KEY=
